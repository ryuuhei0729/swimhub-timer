{
  "name": "split-sync",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w @split-sync/web",
    "build:web": "npm run build -w @split-sync/web",
    "lint:web": "NODE_PATH=$PWD/apps/web/node_modules npm run lint -w @split-sync/web",
    "lint:mobile": "npm run lint -w @split-sync/mobile",
    "dev:mobile": "npm run start -w @split-sync/mobile",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "overrides": {
    "@types/react": "^19.2.14",
    "react-native-screens": "4.16.0"
  },
  "devDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
