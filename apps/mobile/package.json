{
  "name": "@swimhub-timer/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "pnpm exec dotenvx run -f .env.local -- expo start",
    "start:clear": "pnpm exec dotenvx run -f .env.local -- expo start --clear",
    "android": "pnpm exec dotenvx run -f .env.local -- expo run:android",
    "ios": "pnpm exec dotenvx run -f .env.local -- expo run:ios",
    "ios:dev-client": "pnpm exec dotenvx run -f .env.local -- expo start --ios --dev-client",
    "web": "expo start --web",
    "lint": "eslint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "@swimhub-timer/i18n": "*",
    "@swimhub-timer/shared": "*",
    "expo": "~55.0.0",
    "expo-apple-authentication": "~55.0.11",
    "expo-auth-session": "~55.0.12",
    "expo-build-properties": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-crypto": "~55.0.12",
    "expo-dev-client": "~55.0.22",
    "expo-file-system": "~55.0.14",
    "expo-haptics": "~55.0.12",
    "expo-image-picker": "~55.0.16",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-media-library": "~55.0.12",
    "expo-router": "~55.0.10",
    "expo-sharing": "~55.0.16",
    "expo-status-bar": "~55.0.5",
    "expo-video": "~55.0.13",
    "expo-web-browser": "~55.0.12",
    "ffmpeg-kit-react-native": "github:jdarshan5/ffmpeg-kit-react-native#rn-binaries",
    "i18next": "^24.0.0",
    "react": "19.2.4",
    "react-i18next": "^15.0.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-mmkv": "^4.1.2",
    "react-native-purchases": "^9.12.0",
    "react-native-reanimated": "~4.3.0",
    "react-native-worklets": "~0.8.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "4.23.0",
    "react-native-svg": "15.15.3",
    "zustand": "^5.0.11"
  },
  "expo": {
    "install": {
      "exclude": ["react", "react-native-reanimated", "react-native-worklets"]
    }
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@types/react": "~19.1.0",
    "eslint": "^9",
    "eslint-config-expo": "~55.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
